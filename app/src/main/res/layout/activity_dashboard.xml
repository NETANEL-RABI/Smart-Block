<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="לוח בקרה - סינון"
        android:textSize="22sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <Button android:id="@+id/btnStartFilter" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="הפעל סינון (VPN)" android:layout_marginBottom="8dp" />

    <Button android:id="@+id/btnStopFilter" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="עצור סינון" android:layout_marginBottom="8dp" />

    <Button android:id="@+id/btnEnableAccessibility" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="הפעל חסימת אפליקציות" android:layout_marginBottom="8dp" />

    <Button android:id="@+id/btnEnableDeviceAdmin" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="הפעל הגנת מנהל מכשיר" android:layout_marginBottom="8dp" />

    <Button android:id="@+id/btnSchedule" android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="לוח זמנים" />

</LinearLayout>
